{
    "scenario_id": "win11_insider_operational_recon","scenario_name": "national_gallery_insider_operational_recon_attack","scenario_type": "advanced_attack",

"description": "National Gallery DC 사건의 내부 공모자가 작전 실행 전 디지털 환경을 사전 조사한 행위에서 착안하여, 미술관 내부 직원 계정으로 시스템·네트워크·도메인·보안 운영 구조를 정찰하고 보안 감시 체계 및 관리 자산을 분석한 뒤 은닉 작업 디렉터리를 생성하고 일부 흔적을 제거하는 내부자 위협 기반 Operational Reconnaissance 공격 시나리오",

"environment_context": {"environment_type": "single_windows_host",

"os": [
  "Windows 11"
],

"logging_sources": [
  "Windows Security Log",
  "Sysmon Operational Log"
],

"required_logging_configuration": {
  "security_events": [4624, 4634, 4647, 4656, 4663, 4672, 4688],

  "sysmon_events": [1, 3, 11, 22, 26]
}

},

"artifacts_definition": {

"base_directory": "C:\\ProgramData\\MuseumCache\\{A92D1F}",

"recon_script": "C:\\ProgramData\\MuseumCache\\audit_update.ps1",

"security_map_log": "C:\\ProgramData\\MuseumCache\\{A92D1F}\\security_map.dat",

"domain_recon_log": "C:\\ProgramData\\MuseumCache\\{A92D1F}\\domain_layout.tmp",

"share_recon_log": "C:\\ProgramData\\MuseumCache\\{A92D1F}\\share_access.cache",

"monitoring_log": "C:\\ProgramData\\MuseumCache\\{A92D1F}\\monitoring_structure.log",

"cleanup_targets": [
  "C:\\ProgramData\\MuseumCache\\audit_update.ps1",
  "C:\\ProgramData\\MuseumCache\\{A92D1F}\\share_access.cache"
],

"cleanup_survivors": [
  "C:\\ProgramData\\MuseumCache\\{A92D1F}\\security_map.dat",
  "C:\\ProgramData\\MuseumCache\\{A92D1F}\\monitoring_structure.log"
]

},

"scenario_flow": [

{
  "stage_id": 1,
  "stage_name": "authorized_logon",
  "description": "내부 직원 계정 기반 정상 사용자 로그인 세션 생성",
  "action_type": "user_logon",
  "attack": false,

  "mitre_mapping": null,

  "expected_logs": {
    "security": [4624],
    "sysmon": []
  },

  "expected_artifacts": [
    "정상 사용자 로그인 세션",
    "LogonId 기반 세션 정보"
  ],

  "notes": "정상 내부 직원 계정 로그인. 이후 Recon chain의 session anchor 역할"
},

{
  "stage_id": 2,
  "stage_name": "recon_script_deployment",
  "description": "정찰용 PowerShell 스크립트 배치 및 실행 준비",
  "action_type": "script_deployment",
  "attack": true,

  "mitre_mapping": {
    "tactic": "Execution",
    "technique_id": "T1059.001",
    "technique_name": "PowerShell"
  },

  "expected_logs": {
    "security": [4688],
    "sysmon": [1, 11]
  },

  "expected_artifacts": [
    "audit_update.ps1 생성",
    "PowerShell 실행 흔적",
    "ProgramData 하위 스크립트 배치"
  ],

  "notes": "정찰 자동화를 위한 PowerShell script deployment"
},

{
  "stage_id": 3,
  "stage_name": "hidden_operational_directory_creation",
  "description": "Recon 결과 저장을 위한 Hidden/System 속성 작업 디렉터리 생성",
  "action_type": "hidden_directory_creation",
  "attack": true,

  "mitre_mapping": {
    "tactic": "Defense Evasion",
    "technique_id": "T1564.001",
    "technique_name": "Hide Artifacts: Hidden Files and Directories"
  },

  "expected_logs": {
    "security": [4663],
    "sysmon": [11]
  },

  "expected_artifacts": [
    "MuseumCache 디렉터리 생성",
    "Hidden/System attribute 적용",
    "은닉 Recon 작업 공간 생성"
  ],

  "notes": "Recon 결과 및 운영 구조 분석 결과 저장용 은닉 디렉터리 구성"
},

{
  "stage_id": 4,
  "stage_name": "domain_structure_reconnaissance",
  "description": "도메인 및 조직 구조 정찰 수행",
  "action_type": "domain_reconnaissance",
  "attack": true,

  "mitre_mapping": {
    "tactic": "Discovery",
    "technique_id": "T1018",
    "technique_name": "Remote System Discovery"
  },

  "expected_logs": {
    "security": [4688],
    "sysmon": [1, 22]
  },

  "expected_artifacts": [
    "nltest.exe 실행",
    "Domain Controller 조회",
    "도메인 구조 탐색 결과"
  ],

  "notes": "도메인 구조 및 내부 인증 환경 조사. 독립 VM 환경에서는 외부 FQDN으로 DNS 쿼리 수행"
},

{
  "stage_id": 5,
  "stage_name": "privileged_group_mapping",
  "description": "관리자 그룹 및 privileged account 구조 확인",
  "action_type": "account_discovery",
  "attack": true,

  "mitre_mapping": {
    "tactic": "Discovery",
    "technique_id": "T1087.002",
    "technique_name": "Account Discovery: Domain Account"
  },

  "expected_logs": {
    "security": [4688],
    "sysmon": [1]
  },

  "expected_artifacts": [
    "Domain Admins 조회",
    "Administrators 그룹 확인",
    "특권 계정 구조 확인"
  ],

  "notes": "고권한 계정 및 운영 권한 구조 분석"
},

{
  "stage_id": 6,
  "stage_name": "security_monitoring_recon",
  "description": "보안 운영 및 감시 체계 분석",
  "action_type": "security_software_discovery",
  "attack": true,

  "mitre_mapping": {
    "tactic": "Discovery",
    "technique_id": "T1518.001",
    "technique_name": "Software Discovery"
  },

  "expected_logs": {
    "security": [4688],
    "sysmon": [1]
  },

  "expected_artifacts": [
    "보안 프로세스 조회",
    "EDR/AV 존재 확인",
    "보안 운영 구조 분석 결과"
  ],

  "notes": "EDR/AV/Monitoring Agent 존재 여부 확인. 향후 공격 수행 시 탐지 가능성 및 우회 대상 식별 목적."
},

{
  "stage_id": 7,
  "stage_name": "administrative_share_recon",
  "description": "관리 공유 및 접근 가능 자산 조사",
  "action_type": "network_share_discovery",
  "attack": true,

  "mitre_mapping": {
    "tactic": "Discovery",
    "technique_id": "T1135",
    "technique_name": "Network Share Discovery"
  },

  "expected_logs": {
    "security": [4688],
    "sysmon": [1, 3]
  },

  "expected_artifacts": [
    "ADMIN$ 접근 시도",
    "SMB 연결 흔적",
    "공유 자산 조사 기록"
  ],

  "notes": "향후 운영 개입 가능 자산 및 공유 리소스 식별"
},

{
  "stage_id": 8,
  "stage_name": "eventlog_policy_inspection",
  "description": "이벤트 로그 및 감사 정책 구조 조사",
  "action_type": "policy_discovery",
  "attack": true,

  "mitre_mapping": {
    "tactic": "Discovery",
    "technique_id": "T1082",
    "technique_name": "System Information Discovery"
  },

  "expected_logs": {
    "security": [4688],
    "sysmon": [1]
  },

  "expected_artifacts": [
    "wevtutil.exe 실행",
    "로그 보존 정책 조회",
    "감사 정책 구조 확인"
  ],

  "notes": "향후 운영 은닉 가능성 판단을 위한 이벤트 로그 구조 분석"
},

{
  "stage_id": 9,
  "stage_name": "operational_recon_result_staging",
  "description": "정찰 결과를 은닉 작업 디렉터리에 저장",
  "action_type": "data_staging",
  "attack": true,

  "mitre_mapping": {
    "tactic": "Collection",
    "technique_id": "T1074",
    "technique_name": "Data Staged"
  },

  "expected_logs": {
    "security": [4663],
    "sysmon": [11]
  },

  "expected_artifacts": [
    "security_map.dat 생성",
    "domain_layout.tmp 생성",
    "monitoring_structure.log 생성"
  ],

  "notes": "운영 구조 및 보안 감시 결과를 은닉 staging directory에 저장"
},

{
  "stage_id": 10,
  "stage_name": "selective_artifact_cleanup",
  "description": "Recon 스크립트 및 일부 조사 artifact 제거",
  "action_type": "artifact_cleanup",
  "attack": true,

  "mitre_mapping": {
    "tactic": "Defense Evasion",
    "technique_id": "T1070.004",
    "technique_name": "Indicator Removal: File Deletion"
  },

  "expected_logs": {
    "security": [4663, 4688],
    "sysmon": [1, 26]
  },

  "expected_artifacts": [
    "audit_update.ps1 삭제",
    "share_access.cache 삭제",
    "일부 Recon artifact 제거"
  ],

  "notes": "일부 artifact만 제거하며 security_map.dat 및 monitoring_structure.log는 잔존"
},

{
  "stage_id": 11,
  "stage_name": "residual_operational_artifacts",
  "description": "일부 Recon 및 운영 구조 분석 artifact 잔존",
  "action_type": "residual_artifact",
  "attack": false,

  "mitre_mapping": null,

  "expected_logs": {
    "security": [],
    "sysmon": []
  },

  "expected_artifacts": [
    "security_map.dat 잔존",
    "monitoring_structure.log 잔존",
    "은닉 디렉터리 잔존"
  ],

  "notes": "부분 cleanup 이후 일부 Recon artifact 및 은닉 디렉터리 잔존"
},

{
  "stage_id": 12,
  "stage_name": "session_termination",
  "description": "사용자 로그오프 및 세션 종료",
  "action_type": "session_logoff",
  "attack": false,

  "mitre_mapping": null,

  "expected_logs": {
    "security": [4634, 4647],
    "sysmon": []
  },

  "expected_artifacts": [
    "세션 종료",
    "잔존 Recon artifact 유지"
  ],

  "notes": "Recon operation 종료"
}

],

"automation_notes": ["모든 stage는 단일 PowerShell 세션 기반으로 실행 가능","각 stage 사이에는 1~3초 랜덤 sleep 삽입","일부 cleanup 이후에도 artifact 일부는 의도적으로 잔존","정상 내부 직원 행위처럼 보이도록 LOLBin 및 기본 Windows 도구 활용","실패한 접근 시도 역시 forensic evidence로 유지 가능"],

"pre_execution_requirements": ["PowerShell must be executed as Administrator","Sysmon must be installed with Event IDs 1,3,11,22,26 enabled","Windows Security auditing for 4624,4634,4663,4672,4688 must be enabled","At least one accessible SMB share must exist","도메인 환경 또는 테스트용 AD 환경 권장","Object Access auditing 활성화 권장"]}
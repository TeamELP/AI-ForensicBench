{
  "scenario_id": "win11_lolbin_masquerading_intrusion",
  "scenario_name": "living_off_the_land_user_masquerading_attack",
  "scenario_type": "scripted_intrusion",

  "description": "정상 Windows 바이너리(LOLBin)를 악용하여 악성 스크립트를 실행하고, 브라우저 및 Office 기반 사용자 행위 속에 숨은 채 persistence를 확보한 뒤 일부 흔적을 제거하는 공격 시나리오",

  "environment_context": {
    "environment_type": "single_windows_host",

    "hosts": [
      {
        "os": "Windows 11"
      }
    ],

    "logging_sources": [
      "Windows Security Log",
      "Sysmon Operational Log"
    ],

    "required_logging_configuration": {
      "security_events": [4624, 4634, 4647, 4688, 4698],
      "sysmon_events": [1, 3, 11, 26]
    }
  },

  "artifacts_definition": {
    "base_directory": "C:\\ProgramData\\WindowsCache\\{D13A7C}",

    "downloaded_iso": "C:\\Users\\Public\\Downloads\\KB500948.iso",

    "decoded_payload": "C:\\ProgramData\\WindowsCache\\cache.hta",

    "temp_script": "C:\\ProgramData\\WindowsCache\\update.js",

    "bits_queue_directory": "C:\\ProgramData\\Microsoft\\Network\\Downloader\\",

    "bits_job_marker": "C:\\ProgramData\\WindowsCache\\job_created.flag",

    "recent_cleanup_target": "C:\\Users\\Public\\Recent",

    "scheduled_task_name": "WindowsUpdateCache",

    "cleanup_targets": [
      "C:\\ProgramData\\WindowsCache\\cache.hta",
      "C:\\ProgramData\\WindowsCache\\update.js"
    ],

    "cleanup_survivors": [
      "C:\\Users\\Public\\Downloads\\KB500948.iso",
      "C:\\ProgramData\\WindowsCache\\job_created.flag"
    ]
  },

  "scenario_flow": [

    {
      "stage_id": 1,
      "stage_name": "authorized_logon",
      "description": "정상 사용자 세션 로그인",
      "action_type": "user_logon",
      "attack": false,

      "mitre_mapping": null,

      "expected_logs": {
        "security": [4624],
        "sysmon": []
      },

      "expected_artifacts": [
        "정상 사용자 세션 생성"
      ],

      "notes": "공격 이전 정상 로그인 단계"
    },

    {
      "stage_id": 2,
      "stage_name": "browser_download_iso",
      "description": "브라우저 기반 ISO 파일 다운로드",
      "action_type": "file_download",
      "attack": true,

      "mitre_mapping": {
        "tactic": "Initial Access",
        "technique_id": "T1566.002",
        "technique_name": "Phishing: Spearphishing Link"
      },

      "secondary_mitre_mapping": {
        "tactic": "Defense Evasion",
        "technique_id": "T1553.005",
        "technique_name": "Subvert Trust Controls: Mark-of-the-Web Bypass"
      },

      "expected_logs": {
        "security": [4688],
        "sysmon": [3, 11]
      },

      "expected_artifacts": [
        "ISO 파일 다운로드",
        "msedge.exe 외부 HTTP 연결",
        "Zone.Identifier ADS 생성 (ISO 자체에만 적용, 내부 파일에는 미전파)"
      ],

      "notes": "브라우저 기반 악성 ISO 다운로드. ISO 컨테이너 형식 특성상 MotW(Zone.Identifier)가 내부 파일에 전파되지 않아 SmartScreen 우회 가능 (T1553.005). 피싱 링크를 통한 Initial Access (T1566.002)"
    },

    {
      "stage_id": 3,
      "stage_name": "iso_mount_access",
      "description": "ISO 마운트 및 내부 파일 접근",
      "action_type": "mounted_media_execution",
      "attack": true,

      "mitre_mapping": {
        "tactic": "Execution",
        "technique_id": "T1204",
        "technique_name": "User Execution"
      },

      "expected_logs": {
        "security": [4688],
        "sysmon": [1]
      },

      "expected_artifacts": [
        "ISO 마운트 드라이브 생성",
        "Explorer 접근 흔적",
        "ISO 내부 파일 접근"
      ],

      "notes": "사용자가 ISO 파일을 마운트하거나 탐색 후 내부 파일 접근 수행"
    },

    {
      "stage_id": 4,
      "stage_name": "certutil_decode_payload",
      "description": "certutil LOLBin 기반 페이로드 디코딩",
      "action_type": "payload_decode",
      "attack": true,

      "mitre_mapping": {
        "tactic": "Defense Evasion",
        "technique_id": "T1140",
        "technique_name": "Deobfuscate/Decode Files or Information"
      },

      "expected_logs": {
        "security": [4688],
        "sysmon": [1, 11]
      },

      "expected_artifacts": [
        "certutil.exe 실행",
        "cache.hta 생성"
      ],

      "notes": "certutil LOLBin을 이용한 Base64 디코딩 수행"
    },

    {
      "stage_id": 5,
      "stage_name": "mshta_execution",
      "description": "mshta 기반 HTA 실행",
      "action_type": "lolbin_execution",
      "attack": true,

      "mitre_mapping": {
        "tactic": "Execution",
        "technique_id": "T1218.005",
        "technique_name": "Mshta"
      },

      "expected_logs": {
        "security": [4688],
        "sysmon": [1, 3, 11]
      },

      "expected_artifacts": [
        "mshta.exe 실행",
        "외부 HTTP 연결 시도",
        "update.js 생성"
      ],

      "notes": "mshta LOLBin을 통해 HTA를 실행하고 외부 HTTP 연결 및 추가 스크립트(update.js) 드롭 수행"
    },

    {
      "stage_id": 6,
      "stage_name": "rundll32_proxy_execution",
      "description": "rundll32 기반 proxy execution",
      "action_type": "proxy_execution",
      "attack": true,

      "mitre_mapping": {
        "tactic": "Defense Evasion",
        "technique_id": "T1218.011",
        "technique_name": "Rundll32"
      },

      "expected_logs": {
        "security": [4688],
        "sysmon": [1]
      },

      "expected_artifacts": [
        "rundll32.exe 실행",
        "wscript.exe spawn",
        "update.js 실행"
      ],

      "notes": "rundll32 실행 이후 wscript 기반 스크립트 실행 체인을 형성하여 정상 프로세스 흐름처럼 위장"
    },

    {
      "stage_id": 7,
      "stage_name": "bitsadmin_background_transfer",
      "description": "BITS Job 기반 백그라운드 전송 시도",
      "action_type": "background_transfer",
      "attack": true,

      "mitre_mapping": {
        "tactic": "Command and Control",
        "technique_id": "T1197",
        "technique_name": "BITS Jobs"
      },

      "expected_logs": {
        "security": [4688],
        "sysmon": [1, 3, 11]
      },

      "expected_artifacts": [
        "BITS Job 생성",
        "job_created.flag 생성",
        "BITS 큐 파일 변경"
      ],

      "notes": "BITS Job을 이용한 백그라운드 다운로드 구성 및 Queue 기반 artifact 생성"
    },

    {
      "stage_id": 8,
      "stage_name": "office_document_open",
      "description": "Word 프로세스 기반 사용자 행위 위장",
      "action_type": "process_masquerading",
      "attack": true,

      "mitre_mapping": {
        "tactic": "Defense Evasion",
        "technique_id": "T1036",
        "technique_name": "Masquerading"
      },

      "expected_logs": {
        "security": [4688],
        "sysmon": [1]
      },

      "expected_artifacts": [
        "WINWORD.EXE 실행",
        "비정상 parent-child chain",
        "RecentDocs/LNK 흔적 생성"
      ],

      "notes": "wscript.exe가 Word를 spawn하여 정상 업무 행위처럼 위장"
    },

    {
      "stage_id": 9,
      "stage_name": "scheduled_task_persistence",
      "description": "Scheduled Task 기반 persistence 생성",
      "action_type": "scheduled_task_creation",
      "attack": true,

      "mitre_mapping": {
        "tactic": "Persistence",
        "technique_id": "T1053.005",
        "technique_name": "Scheduled Task"
      },

      "expected_logs": {
        "security": [4698, 4688],
        "sysmon": [1]
      },

      "expected_artifacts": [
        "Scheduled Task 생성",
        "Task XML 생성",
        "schtasks.exe 실행"
      ],

      "notes": "schtasks 기반 persistence 확보"
    },

    {
      "stage_id": 10,
      "stage_name": "browser_history_cleanup",
      "description": "브라우저 흔적 제거",
      "action_type": "browser_artifact_cleanup",
      "attack": true,

      "mitre_mapping": {
        "tactic": "Defense Evasion",
        "technique_id": "T1070",
        "technique_name": "Indicator Removal on Host"
      },

      "expected_logs": {
        "security": [],
        "sysmon": [1, 26]
      },

      "expected_artifacts": [
        "Edge History 삭제",
        "브라우저 흔적 일부 제거"
      ],

      "notes": "브라우저 기록 삭제 시도 수행"
    },

    {
      "stage_id": 11,
      "stage_name": "recentdocs_cleanup",
      "description": "중간 페이로드 및 RecentDocs 흔적 제거",
      "action_type": "artifact_cleanup",
      "attack": true,

      "mitre_mapping": {
        "tactic": "Defense Evasion",
        "technique_id": "T1070.004",
        "technique_name": "File Deletion"
      },

      "expected_logs": {
        "security": [],
        "sysmon": [26]
      },

      "expected_artifacts": [
        "cache.hta 삭제",
        "update.js 삭제",
        "RecentDocs/LNK 삭제",
        "job_created.flag 잔존"
      ],

      "notes": "중간 payload 및 RecentDocs 흔적 제거 수행.  일부 잔존"
    },

    {
      "stage_id": 12,
      "stage_name": "session_termination",
      "description": "사용자 세션 종료",
      "action_type": "session_logoff",
      "attack": false,

      "mitre_mapping": null,

      "expected_logs": {
        "security": [4634, 4647],
        "sysmon": []
      },

      "expected_artifacts": [
        "세션 종료",
        "BITS Job 및 Scheduled Task 잔존"
      ],

      "notes": "공격 종료 후 persistence artifact 일부 유지"
    }
  ],

  "automation_notes": [
  "All stages execute within a single PowerShell session",
  "Random sleep intervals are inserted between stages",
  "Failed network connections may still generate forensic artifacts",
  "Loopback/localhost traffic may be used for stable Sysmon Event ID 3 generation",
  "Some persistence artifacts intentionally survive cleanup",
  "Failed stages are still treated as valid forensic evidence"
  ],
  
  "pre_execution_requirements": [
  "PowerShell must run as Administrator",
  "Sysmon must be installed with Event IDs 1, 3, 11, and 26 enabled",
  "Windows Security auditing for 4688 and 4698 must be enabled",
  "Microsoft Edge, mshta, wscript, and BITS service must be available",
  "At least one active network adapter must exist"
  ]
}
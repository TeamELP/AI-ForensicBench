{
  "scenario_id": "win11_byovd_kernel_rootkit_simulation",
  "scenario_name": "byovd_kernel_artifact_manipulation_attack",
  "scenario_type": "scripted_intrusion",

  "description": "취약 드라이버(BYOVD)를 시스템에 적재하여 커널 수준 접근 capability를 확보하고, 보안 제품 탐지 및 권한 검증 이후 LSASS 접근 및 메모리 조작 흔적을 남긴 뒤 일부 kernel artifact 제거를 시도하지만 드라이버 및 메모리 흔적은 잔존하는 Windows 기반 Kernel DFIR Simulation 시나리오",

  "environment_context": {
    "environment_type": "single_windows_host",

    "os": [
      "Windows 11"
    ],

    "logging_sources": [
      "Windows Security Log",
      "Sysmon Operational Log"
    ],

    "required_logging_configuration": {
      "security_events": [
        4624,
        4634,
        4656,
        4688,
        4697
      ],

      "sysmon_events": [
        1,
        6,
        10,
        11,
        26
      ]
    }
  },

  "artifacts_definition": {
    "driver_directory": "C:\\ProgramData\\WinDrv",

    "driver_file": "C:\\ProgramData\\WinDrv\\RTCore64.sys",

    "helper_loader": "C:\\ProgramData\\WinDrv\\drvloader.exe",

    "memory_tool": "C:\\ProgramData\\WinDrv\\memctl.exe",

    "temporary_log": "C:\\ProgramData\\WinDrv\\kern.tmp",

    "credential_dump_simulation": "C:\\ProgramData\\WinDrv\\lsass_sim.dmp",

    "service_name": "WinDrv",

    "service_registry": "HKLM\\SYSTEM\\CurrentControlSet\\Services\\WinDrv",

    "prefetch_targets": [
      "C:\\Windows\\Prefetch\\DRVLOADER.EXE-*.pf",
      "C:\\Windows\\Prefetch\\MEMCTL.EXE-*.pf"
    ]
  },

  "scenario_flow": [

    {
      "stage_id": 1,
      "stage_name": "authorized_logon",
      "description": "공격 수행 전 정상 사용자 세션 생성",
      "action_type": "user_logon",
      "attack": false,
      "mitre_mapping": null,
      "expected_logs": {
        "security": [4624],
        "sysmon": []
      },
      "expected_artifacts": [
        "정상 사용자 세션 생성",
        "로그온 세션 baseline 생성"
      ],
      "notes": "공격 시작 이전 정상 로그인 세션 생성 단계"
    },

    {
      "stage_id": 2,
      "stage_name": "privilege_validation",
      "description": "현재 사용자 계정이 관리자 권한 및 특권을 보유하는지 확인",
      "action_type": "privilege_validation",
      "attack": true,
      "mitre_mapping": {
        "tactic": "Discovery",
        "technique_id": "T1033",
        "technique_name": "System Owner/User Discovery"
      },
      "expected_logs": {
        "security": [4688],
        "sysmon": [1]
      },
      "expected_artifacts": [
        "whoami /priv 실행 흔적",
        "관리자 권한 확인 흔적",
        "privilege enumeration artifact"
      ],
      "notes": "driver load 이전 현재 권한 상태 확인 단계"
    },

    {
      "stage_id": 3,
      "stage_name": "security_product_discovery",
      "description": "보안 제품 및 Defender 동작 여부 확인",
      "action_type": "security_software_discovery",
      "attack": true,
      "mitre_mapping": {
        "tactic": "Discovery",
        "technique_id": "T1518.001",
        "technique_name": "Security Software Discovery"
      },
      "expected_logs": {
        "security": [4688],
        "sysmon": [1]
      },
      "expected_artifacts": [
        "Defender service query 흔적",
        "security software enumeration 흔적",
        "EDR/AV 탐지 확인 행위"
      ],
      "notes": "BYOVD 수행 전 security product 존재 여부 확인 단계"
    },

    {
      "stage_id": 4,
      "stage_name": "driver_staging",
      "description": "취약 드라이버 및 보조 도구를 디스크에 배치",
      "action_type": "driver_staging",
      "attack": true,
      "mitre_mapping": {
        "tactic": "Command and Control",
        "technique_id": "T1105",
        "technique_name": "Ingress Tool Transfer"
      },
      "expected_logs": {
        "security": [4688],
        "sysmon": [1, 11]
      },
      "expected_artifacts": [
        "C:\\ProgramData\\WinDrv 디렉터리 생성",
        "RTCore64.sys 파일 생성",
        "drvloader.exe 파일 생성",
        "memctl.exe 파일 생성",
        "driver staging 흔적"
      ],
      "notes": "취약 driver 및 helper tool staging 단계"
    },

    {
      "stage_id": 5,
      "stage_name": "kernel_service_creation",
      "description": "드라이버 로드를 위해 커널 서비스 등록",
      "action_type": "kernel_service_creation",
      "attack": true,
      "mitre_mapping": {
        "tactic": "Persistence",
        "technique_id": "T1543.003",
        "technique_name": "Windows Service"
      },
      "expected_logs": {
        "security": [4688, 4697],
        "sysmon": [1]
      },
      "expected_artifacts": [
        "WinDrv kernel service 생성",
        "HKLM\\SYSTEM\\CurrentControlSet\\Services\\WinDrv 생성",
        "서비스 등록 흔적"
      ],
      "notes": "취약 Driver를 Windows Kernel Service로 등록. Registry의 Services 영역에 Driver Service Artifact 생성."
    },

    {
      "stage_id": 6,
      "stage_name": "driver_load",
      "description": "등록된 취약 드라이버를 로드하여 커널 수준 접근 확보",
      "action_type": "driver_load",
      "attack": true,
      "mitre_mapping": {
        "tactic": "Persistence",
        "technique_id": "T1547.006",
        "technique_name": "Kernel Modules and Extensions"
      },
      "expected_logs": {
        "security": [4688],
        "sysmon": [1, 6]
      },
      "expected_artifacts": [
        "Sysmon Event 6 Driver Loaded",
        "RTCore64.sys driver load",
        "kernel module registration 흔적"
      ],
      "notes": "취약 driver load 단계. 실제 exploit 없이 kernel capability artifact만 생성"
    },

    {
      "stage_id": 7,
      "stage_name": "driver_validation",
      "description": "드라이버가 정상적으로 로드되었는지 상태 검증",
      "action_type": "driver_validation",
      "attack": true,
      "mitre_mapping": {
        "tactic": "Discovery",
        "technique_id": "T1518",
        "technique_name": "Software Discovery"
      },
      "expected_logs": {
        "security": [4688],
        "sysmon": [1]
      },
      "expected_artifacts": [
        "sc query WinDrv 실행",
        "sc queryex WinDrv 실행",
        "driver service 상태 확인",
        "driver load validation 흔적"
      ],
      "notes": "driver가 실제 로드되었는지 상태 확인 수행"
    },

    {
      "stage_id": 8,
      "stage_name": "memory_tool_execution",
      "description": "드라이버와 통신할 사용자 모드 도구 실행",
      "action_type": "memory_tool_execution",
      "attack": true,
      "mitre_mapping": {
        "tactic": "Execution",
        "technique_id": "T1106",
        "technique_name": "Native API"
      },
      "expected_logs": {
        "security": [4688],
        "sysmon": [1]
      },
      "expected_artifacts": [
        "memctl.exe 프로세스 생성",
        "MEMCTL.EXE Prefetch 생성",
        "kernel memory interaction 준비 흔적"
      ],
      "notes": "Driver와 상호작용하는 Helper Tool(memctl.exe)을 실행. 이후 LSASS 접근 및 Process Access 행위의 Source Process 역할 수행."
    },

    {
      "stage_id": 9,
      "stage_name": "lsass_handle_access",
      "description": "LSASS 프로세스에 대한 메모리 접근 권한 획득 시도",
      "action_type": "lsass_memory_access",
      "attack": true,
      "mitre_mapping": {
        "tactic": "Credential Access",
        "technique_id": "T1003.001",
        "technique_name": "LSASS Memory"
      },
      "expected_logs": {
        "security": [4656],
        "sysmon": [10]
      },
      "expected_artifacts": [
        "Sysmon Event 10 ProcessAccess",
        "powershell.exe → lsass.exe 접근",
        "PROCESS_VM_READ 권한 요청 (0x1001410)"
      ],
      "notes": "실제 credential dump 없이 LSASS handle access artifact만 생성. OpenProcess P/Invoke 특성상 source process는 powershell.exe로 기록됨 (memctl.exe 아님)"
    },

    {
      "stage_id": 10,
      "stage_name": "credential_collection",
      "description": "LSASS 메모리 덤프를 모사하는 아티팩트 생성",
      "action_type": "credential_collection",
      "attack": true,
      "mitre_mapping": {
        "tactic": "Credential Access",
        "technique_id": "T1003",
        "technique_name": "OS Credential Dumping"
      },
      "expected_logs": {
        "security": [4688],
        "sysmon": [1, 11]
      },
      "expected_artifacts": [
        "lsass_sim.dmp 생성",
        "dump simulation artifact",
        "credential dumping semantic 흔적"
      ],
      "notes": "실제 LSASS dump 없이 forensic용 dump artifact만 생성"
    },

    {
      "stage_id": 11,
      "stage_name": "suspicious_memory_activity",
      "description": "svchost 프로세스 대상 메모리 조작 행위 시뮬레이션",
      "action_type": "process_injection_simulation",
      "attack": true,
      "mitre_mapping": {
        "tactic": "Defense Evasion",
        "technique_id": "T1055",
        "technique_name": "Process Injection"
      },
      "expected_logs": {
        "security": [],
        "sysmon": [10]
      },
      "expected_artifacts": [
        "memctl.exe → svchost.exe ProcessAccess",
        "PROCESS_ALL_ACCESS 요청",
        "Injection-like memory activity 흔적"
      ],
      "notes": "실제 shellcode injection 없이 ProcessAccess 기반 injection simulation artifact 생성"
    },

    {
      "stage_id": 12,
      "stage_name": "rootkit_behavior",
      "description": "Rootkit과 유사한 비정상 프로세스 계층 및 커널 흔적 생성",
      "action_type": "rootkit_behavior",
      "attack": true,
      "mitre_mapping": {
        "tactic": "Defense Evasion",
        "technique_id": "T1014",
        "technique_name": "Rootkit"
      },
      "expected_logs": {
        "security": [4688],
        "sysmon": [1, 11]
      },
      "expected_artifacts": [
        "짧은 수명의 cmd.exe child process",
        "비정상 process tree",
        "kern.tmp 생성",
        "Sysmon Event 11 File Create"
      ],
      "notes": "실제 EPROCESS unlink 없이 rootkit-like abnormal process lineage simulation"
    },

    {
      "stage_id": 13,
      "stage_name": "eventlog_cleanup_attempt",
      "description": "이벤트 로그 삭제를 시도하여 공격 흔적 은닉 시도",
      "action_type": "eventlog_cleanup_attempt",
      "attack": true,
      "mitre_mapping": {
        "tactic": "Defense Evasion",
        "technique_id": "T1070.001",
        "technique_name": "Clear Windows Event Logs"
      },
      "expected_logs": {
        "security": [4688],
        "sysmon": [1]
      },
      "expected_artifacts": [
        "wevtutil 실행 흔적",
        "event log tampering attempt",
        "부분 실패 cleanup 흔적"
      ],
      "notes": "실제 로그 삭제 대신 event log cleanup 시도 artifact만 생성"
    },

    {
      "stage_id": 14,
      "stage_name": "driver_unload_attempt",
      "description": "드라이버 서비스 중지 및 커널 흔적 제거 시도",
      "action_type": "driver_unload_attempt",
      "attack": true,
      "mitre_mapping": {
        "tactic": "Defense Evasion",
        "technique_id": "T1070.009",
        "technique_name": "Clear Persistence"
      },
      "expected_logs": {
        "security": [4688],
        "sysmon": [1]
      },
      "expected_artifacts": [
        "driver service stop 시도",
        "부분 unload 흔적",
        "잔존 driver object 가능성"
      ],
      "notes": "공격 종료 전 Driver Service를 중지하여 Persistence 흔적 제거를 시도. 완전한 제거가 아닌 부분 제거를 가정."
    },

    {
      "stage_id": 15,
      "stage_name": "registry_cleanup_attempt",
      "description": "서비스 레지스트리 키 삭제 시도",
      "action_type": "registry_cleanup_attempt",
      "attack": true,
      "mitre_mapping": {
        "tactic": "Defense Evasion",
        "technique_id": "T1112",
        "technique_name": "Modify Registry"
      },
      "expected_logs": {
        "security": [4688],
        "sysmon": [1]
      },
      "expected_artifacts": [
        "Services\\WinDrv registry delete 시도",
        "registry tampering 흔적",
        "부분 cleanup 흔적"
      ],
      "notes": "서비스 registry artifact 제거 시도 단계"
    },

    {
      "stage_id": 16,
      "stage_name": "kernel_artifact_cleanup",
      "description": "일부 파일 아티팩트 삭제를 통한 흔적 제거 시도",
      "action_type": "artifact_cleanup",
      "attack": true,
      "mitre_mapping": {
        "tactic": "Defense Evasion",
        "technique_id": "T1070.004",
        "technique_name": "File Deletion"
      },
      "expected_logs": {
        "security": [],
        "sysmon": [26]
      },
      "expected_artifacts": [
        "kern.tmp 삭제",
        "drvloader.exe 삭제",
        "부분 cleanup 흔적",
        "RTCore64.sys 및 memctl.exe 잔존"
      ],
      "notes": "일부 artifact만 삭제하여 incomplete cleanup 재현"
    },

    {
      "stage_id": 17,
      "stage_name": "residual_artifact_state",
      "description": "제거 실패로 인해 주요 커널 및 메모리 흔적이 잔존한 상태 확인",
      "action_type": "residual_artifact_state",
      "attack": false,
      "mitre_mapping": null,
      "expected_logs": {
        "security": [],
        "sysmon": []
      },
      "expected_artifacts": [
        "RTCore64.sys 잔존",
        "memctl.exe 잔존",
        "DriverLoad 기록 잔존",
        "LSASS ProcessAccess 기록 잔존",
        "Prefetch artifact 잔존",
        "Registry service key 일부 잔존"
      ],
      "notes": "cleanup 이후에도 residual kernel 및 memory artifact가 남아 DFIR 분석 가능 상태 유지"
    },

    {
      "stage_id": 18,
      "stage_name": "session_termination",
      "description": "공격 종료 후 사용자 세션 로그오프",
      "action_type": "session_logoff",
      "attack": false,
      "mitre_mapping": null,
      "expected_logs": {
        "security": [4634],
        "sysmon": []
      },
      "expected_artifacts": [
        "사용자 세션 종료"
      ],
      "notes": "공격 종료 및 세션 종료 단계"
    }

  ],

    "automation_notes": {
    "execution_principle": "BYOVD 기반 Driver Load 후 LSASS 접근 및 Memory Activity 수행",
    "design_goal": "Kernel Artifact 및 Credential Access 흔적 생성 후 Cleanup 시도",
    "safe_but_real_actions": [
      "Driver Load",
      "LSASS Access",
      "Memory Activity",
      "Registry Cleanup Attempt",
      "File Cleanup"
    ],
    "pre_execution_requirements": [
      "Windows 11",
      "Administrator 권한",
      "Sysmon 설치",
      "RTCore64.sys 준비"
    ]
  }
}










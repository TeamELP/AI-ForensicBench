{
  "scenario_id": "win11_service_manipulation_ics_variant",
  "scenario_name": "메모리기반_Service_Manipulation_혼합행위_추론형_시나리오",
  "scenario_type": "advanced_attack",

  "description": "탈취된 내부 계정을 이용한 공격자가 시스템 서비스 및 설정을 반복적으로 변조하여 기능 이상을 유발하고 일부 흔적을 제거하는 혼합행위 기반 추론형 시나리오",

  "environment_context": {
    "environment_type": "single_windows_host",
    "os": ["Windows Server 2022"],
    "logging_sources": [
      "Windows Security Log",
      "Sysmon Operational Log",
      "Windows System Log"
    ],
    "required_logging_configuration": {
      "security_events": [4624, 4634, 4647, 4656, 4663, 4672, 4688],
      "sysmon_events": [1, 11, 26],
      "system_events": [7036, 7040]
    }
  },

  "artifacts_definition": {
    "base_directory": "C:\\ProgramData\\SysControl\\{A1B2C3}",
    "hosts_file": "C:\\Windows\\System32\\drivers\\etc\\hosts",
    "service_log": "C:\\ProgramData\\SysControl\\svc.log",
    "disruption_status_log": "C:\\ProgramData\\SysControl\\{A1B2C3}\\disruption_status.log",

    "cleanup_targets": [
      "C:\\ProgramData\\SysControl\\svc.log"
    ],

    "cleanup_survivors": [
      "C:\\Windows\\System32\\drivers\\etc\\hosts",
      "C:\\ProgramData\\SysControl\\{A1B2C3}\\disruption_status.log"
    ]
  },

  "scenario_flow": [

    {
      "stage_id": 1,
      "stage_name": "authorized_logon",
      "description": "정상 사용자 세션 생성",
      "action_type": "logon_session",
      "attack": false,
      "mitre_mapping": null,
      "expected_logs": {
        "security": [4624],
        "sysmon": [],
        "system": []
      },
      "expected_artifacts": [
        "정상 사용자 로그인 세션",
        "LogonId 기반 세션 식별 정보"],
      "notes": "정상 사용자 로그인 세션 생성. 이후 공격 체인의 LogonId anchor 역할"
    },

    {
      "stage_id": 2,
      "stage_name": "system_discovery",
      "description": "systeminfo 기반 시스템 환경 정보 수집",
      "action_type": "system_discovery",
      "attack": true,
      "mitre_mapping": {
        "tactic": "Discovery",
        "technique_id": "T1082",
        "technique_name": "System Information Discovery"
      },
      "expected_logs": {
        "security": [4688],
        "sysmon": [1],
        "system": []
      },
      "expected_artifacts": [
        "systeminfo.exe 프로세스 실행 흔적",
        "프로세스 생성 메타데이터",
        "시스템 정보 조회 행위 흔적"
      ],
      "notes": "systeminfo.exe 실행을 통한 시스템 정보 정찰. PowerShell 기반 공격 체인 시작"
    },

    {
      "stage_id": 3,
      "stage_name": "service_enumeration",
      "description": "sc.exe query를 통한 서비스 열거",
      "action_type": "service_discovery",
      "attack": true,
      "mitre_mapping": {
        "tactic": "Discovery",
        "technique_id": "T1007",
        "technique_name": "System Service Discovery"
      },
      "expected_logs": {
        "security": [4688],
        "sysmon": [1],
        "system": []
      },
      "expected_artifacts": [
        "sc.exe 프로세스 실행 흔적",
        "서비스 목록 조회 행위 흔적"
      ],
      "notes": "전체 서비스 목록 탐색 및 제어 대상 서비스 식별"
    },

    {
      "stage_id": 4,
      "stage_name": "service_config_modification_success",
      "description": "서비스 시작 유형 변경 시도 및 성공",
      "action_type": "service_modification",
      "attack": true,
      "mitre_mapping": {
        "tactic": "Defense Evasion",
        "technique_id": "T1562.001",
        "technique_name": "Impair Defenses"
      },
      "expected_logs": {
        "security": [4663, 4688],
        "sysmon": [1],
        "system": [7040]
      },
      "expected_artifacts": [
        "서비스 시작 유형 변경 흔적",
        "서비스 설정 변경 메타데이터",
        "SCM(Service Control Manager) 설정 변경 기록"
      ],
      "notes": "서비스 시작 유형 disabled 변경 성공. 서비스 기반 방어 기능 약화 목적 가능"
    },

    {
      "stage_id": 5,
      "stage_name": "hosts_file_tampering",
      "description": "hosts 파일 수정 및 로컬 주소 추가",
      "action_type": "file_modification",
      "attack": true,
      "mitre_mapping": {
        "tactic": "Defense Evasion",
        "technique_id": "T1565.001",
        "technique_name": "Data Manipulation"
      },
      "expected_logs": {
        "security": [4656, 4663],
        "sysmon": [11],
        "system": []
      },
      "expected_artifacts": [
        "hosts 파일 수정 흔적",
        "로컬 주소 매핑 추가 기록",
        "파일 수정 시간 변경 흔적"
      ],
      "notes": "hosts 파일 변조를 통한 DNS 우회 또는 내부 트래픽 조작 가능성"
    },

    {
      "stage_id": 6,
      "stage_name": "service_stop_attempt_fail",
      "description": "서비스 중지 시도 실패",
      "action_type": "service_stop",
      "attack": true,
      "mitre_mapping": {
        "tactic": "Impact",
        "technique_id": "T1489",
        "technique_name": "Service Stop"
      },
      "expected_logs": {
        "security": [4688],
        "sysmon": [1],
        "system": []
      },
      "expected_artifacts": [
        "서비스 중지 실패 흔적",
        "sc.exe 실행 기록"
      ],
      "notes": "권한 부족 또는 서비스 의존성으로 인한 서비스 중지 실패"
    },

    {
      "stage_id": 7,
      "stage_name": "service_recovery_policy_manipulation",
      "description": "서비스 recovery 및 failure action 정책 변경",
      "action_type": "service_policy_modification",
      "attack": true,
      "mitre_mapping": {
        "tactic": "Defense Evasion",
        "technique_id": "T1562.001",
        "technique_name": "Impair Defenses"
      },
      "expected_logs": {
        "security": [4663, 4688],
        "sysmon": [1],
        "system": []
      },
      "expected_artifacts": [
        "서비스 복구 정책 변경 흔적",
        "Failure Action 설정 변경 기록",
        "서비스 제어 설정 변경 메타데이터"
      ],
      "notes": "서비스 failure action 및 recovery 정책 조작을 통해 비정상 상태 지속 유도 가능"
    },

    {
      "stage_id": 8,
      "stage_name": "service_stop_retry_success",
      "description": "서비스 중지 성공",
      "action_type": "service_stop",
      "attack": true,
      "mitre_mapping": {
        "tactic": "Impact",
        "technique_id": "T1489",
        "technique_name": "Service Stop"
      },
      "expected_logs": {
        "security": [4688],
        "sysmon": [1],
        "system": [7036]
      },
      "expected_artifacts": [
        "서비스 상태 전환 기록",
        "서비스 중지 상태 흔적",
        "SCM 상태 변경 이벤트"
      ],
      "notes": "서비스 상태 Running → Stopped 전환 발생"
    },

    {
      "stage_id": 9,
      "stage_name": "service_restart_loop_attempt",
      "description": "서비스 재시작 반복 시도",
      "action_type": "service_restart",
      "attack": true,
      "mitre_mapping": {
        "tactic": "Impact",
        "technique_id": "T1499",
        "technique_name": "Endpoint Denial of Service"
      },
      "expected_logs": {
        "security": [4688],
        "sysmon": [1],
        "system": [7036]
      },
      "expected_artifacts": [
        "반복적인 서비스 재시작 시도 흔적",
        "서비스 상태 전환 기록",
        "비정상 서비스 재시작 패턴"
      ],
      "notes": "반복 서비스 시작 시도 및 상태 불안정 유도"
    },

    {
      "stage_id": 10,
      "stage_name": "service_restart_loop_retry",
      "description": "서비스 start/stop 루프 반복",
      "action_type": "service_state_manipulation",
      "attack": true,
      "mitre_mapping": {
        "tactic": "Impact",
        "technique_id": "T1499",
        "technique_name": "Endpoint Denial of Service"
      },
      "expected_logs": {
        "security": [4688],
        "sysmon": [1],
        "system": [7036]
      },
      "expected_artifacts": [
        "서비스 Start/Stop 반복 흔적",
        "서비스 불안정 상태 기록",
        "반복적인 SCM 상태 변경 이벤트"
      ],
      "notes": "서비스 상태 반복 교번 및 시스템 불안정 유발"
    },

    {
      "stage_id": 11,
      "stage_name": "service_disruption_observed",
      "description": "서비스 장애 상태 확인 및 상태 기록 로그 생성",
      "action_type": "service_status_check",
      "attack": true,
      "mitre_mapping": {
        "tactic": "Impact",
        "technique_id": "T1489",
        "technique_name": "Service Stop"
      },
      "expected_logs": {
        "security": [4688],
        "sysmon": [1, 11],
        "system": []
      },
      "expected_artifacts": [
        "svc.log 파일 생성 흔적",
        "서비스 상태 모니터링 기록",
        "서비스 장애 상태 기록 로그"
      ],
      "notes": "상태 확인 결과를 disruption_status.log에 기록하며, 파일 생성 시 Sysmon EID 11 correlation 가능. 기존 svc.log에도 append 가능"
    },

    
    {
      "stage_id": 12,
      "stage_name": "log_deletion_attempt_fail",
      "description": "시스템 오류로 인해 삭제가 중단됨",
      "action_type": "eventlog_tampering_attempt",
      "attack": true,

      "mitre_mapping": {
        "tactic": "Defense Evasion",
        "technique_id": "T1070.001",
        "technique_name": "Clear Windows Event Logs"
      },

      "expected_logs": {
        "security": [4688],
        "sysmon": [1],
        "system": []
      },
      "expected_artifacts": [
        "wevtutil.exe 실행 흔적",
        "이벤트 로그 삭제 실패 흔적",
        "잘못된 백업 경로 참조 기록"
      ],
      "notes": "wevtutil cl Security /bu: 옵션을 사용하여 백업 후 로그 삭제를 시도하지만, 존재하지 않는 백업 경로 지정으로 인해 백업 단계에서 실패하며 Clear 동작은 수행되지 않음. 권한 부족이 아닌 환경적 오류 기반 실패이며, 이후 Stage 13에서 부분 artifact cleanup 방식으로 전환"
    },


    {
      "stage_id": 13,
      "stage_name": "log_deletion_retry_partial_success",
      "description": "svc.log 파일 삭제 성공",
      "action_type": "file_delete",
      "attack": true,
      "mitre_mapping": {
        "tactic": "Defense Evasion",
        "technique_id": "T1070.004",
        "technique_name": "Indicator Removal: File Deletion"
      },
      "expected_logs": {
        "security": [4663],
        "sysmon": [26],
        "system": []
      },
      "expected_artifacts": [
        "svc.log 파일 삭제 흔적",
        "파일 삭제 메타데이터",
        "hosts 파일 잔존 흔적"
      ],
      "notes": "svc.log 삭제 성공. hosts 파일 흔적은 유지"
    },

    {
      "stage_id": 14,

      "stage_name": "session_termination",
      "description": "사용자 로그오프 및 세션 종료",
      "action_type": "process_exit",
      "attack": false,
      "mitre_mapping": null,
      "expected_logs": {
        "security": [4634, 4647],
        "sysmon": [],
        "system": []
      },
      "expected_artifacts": [
        "사용자 로그오프 기록",
        "세션 종료 흔적"
      ],
      "notes": "공격 세션 종료. LogonId 기반 전체 세션 추적 가능"
    }

  ],

  "automation_notes": [
    "Record-GT is triggered only for attack actions",
    "Each stage includes a random sleep between 1~3 seconds",
    "Failed actions must still trigger GT to preserve attack intent",
    "Logs are collected after full scenario execution using a defined time window",
    "All artifacts must be created under base_directory",
    "Noise activities are executed but not recorded in GT"
  ],

  "pre_execution_requirements": [
    "PowerShell must be executed as Administrator",
    "Sysmon must be installed with Event IDs 1,11,26 enabled",
    "Audit Policy: File System auditing must be enabled",
    "Windows Security auditing for Process Creation (4688) must be enabled",
    "At least one active network interface must exist",
    "테스트용 서비스(TargetService)가 존재해야 함"
  ]
}